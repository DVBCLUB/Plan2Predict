# Plan2Predict / LedgerFlow Studio environment variables

# Server runtime
NODE_ENV=production
PORT=8080

# Gemini backend API
# Do not commit real API keys. Configure this in Cloud Run environment variables or secrets.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Basic API protection
# Maximum prompt length accepted by /api/gemini/generate
MAX_PROMPT_LENGTH=12000

# Simple in-memory rate limit per IP and per process
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20
