{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "plan2predict",
          "region": "asia-southeast1",
          "pinTag": true
        }
      }
    ]
  }
}
